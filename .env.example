# Copiar a .env (no se sube a git) y completar con tu connection string real.
MONGODB_URI=mongodb+srv://usuario:password@tu-cluster.mongodb.net/apiWaifu
PORT=4000

# Lista de API keys validas separadas por coma, requeridas por el header
# X-API-Key en todos los endpoints de /api/characters.
API_KEYS=cambia-esta-key

# Si es "true", salta la validacion de API key (solo para desarrollo local).
DISABLE_AUTH=false
